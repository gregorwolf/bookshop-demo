###
# @name readProdUnivHierProdByHierNode
GET {{$dotenv s4hanahost}}/sap/opu/odata4/sap/api_prod_hier_prods_srv/srvd_a2x/sap/prodhierprods/0001/ProdUnivHierProdByHierNode
  ?$top=10
  &$filter=ProdUnivHierarchy eq '{{$dotenv ProdUnivHierarchy}}' and ProdHierarchyValidityEndDate ge 2026-06-01 and Product eq '{{$dotenv ProdUnivHierarchyProduct}}'
  #&$select=ParentNode
  #&$expand=*
  &$count=true
Authorization: Basic {{$dotenv s4hana_username}}:{{$dotenv s4hana_password}}
Accept: application/json
###
@ParentNode={{readProdUnivHierProdByHierNode.response.body.value[0].ParentNode}}
@etag={{readProdUnivHierProdByHierNode.response.body.value[0]["@odata.etag"]}}
### Read ProdUnivHierNormalNode
GET {{$dotenv s4hanahost}}/sap/opu/odata4/sap/api_prod_hier_prods_srv/srvd_a2x/sap/prodhierprods/0001/ProdUnivHierNormalNode
  ?$top=10
  &$filter=ProdUnivHierarchy eq '{{$dotenv ProdUnivHierarchy}}' and HierarchyNode eq '{{ParentNode}}' and ProdHierarchyValidityEndDate ge 2026-06-01
  &$count=true
Authorization: Basic {{$dotenv s4hana_username}}:{{$dotenv s4hana_password}}
Accept: application/json
###
GET {{$dotenv s4hanahost}}/sap/opu/odata4/sap/api_prod_hier_prods_srv/srvd_a2x/sap/prodhierprods/0001/ProdUnivHierNormalNode(ProdUnivHierarchy='{{$dotenv ProdUnivHierarchy}}',HierarchyNode='{{ParentNode}}',ProdHierarchyValidityEndDate=9999-12-31)
  ?$expand=*
Authorization: Basic {{$dotenv s4hana_username}}:{{$dotenv s4hana_password}}
Accept: application/json
### Get CSRF Token
# @name getCSRF
HEAD {{$dotenv s4hanahost}}/sap/opu/odata4/sap/api_prod_hier_prods_srv/srvd_a2x/sap/prodhierprods/0001/
X-CSRF-Token: Fetch
Authorization: Basic {{$dotenv s4hana_username}}:{{$dotenv s4hana_password}}
### Read Token to Variable
@CSRF={{getCSRF.response.headers.x-csrf-token}}
###
POST {{$dotenv s4hanahost}}/sap/opu/odata4/sap/api_prod_hier_prods_srv/srvd_a2x/sap/prodhierprods/0001/ProdUnivHierNormalNode(ProdUnivHierarchy='{{$dotenv ProdUnivHierarchy}}',HierarchyNode='{{ParentNode}}',ProdHierarchyValidityEndDate=9999-12-31)/_ProdUnivHierProdByHierNode
Authorization: Basic {{$dotenv s4hana_username}}:{{$dotenv s4hana_password}}
X-CSRF-Token: {{CSRF}}
Accept: application/json
Content-Type: application/json

{
  "ProdUnivHierarchy" : "{{$dotenv ProdUnivHierarchy}}",
  "HierarchyNode" : "{{$dotenv Product}}",
  "ProdHierarchyValidityEndDate" : "9999-12-31",
  "Product" : "{{$dotenv Product}}"
}
